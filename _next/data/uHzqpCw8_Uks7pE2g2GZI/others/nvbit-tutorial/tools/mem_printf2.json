":"CUPTI Finalization and Cleanup Tutorial","href":"/others/cupti-tutorial/cupti_finalize/","depth":2},{"title":"CUPTI Metric Properties Tutorial","href":"/others/cupti-tutorial/cupti_metric_properties/","depth":2},{"title":"CUPTI NVTX Integration Tutorial","href":"/others/cupti-tutorial/cupti_nvtx/","depth":2},{"title":"CUPTI Query API Tutorial","href":"/others/cupti-tutorial/cupti_query/","depth":2},{"title":"CUPTI Trace Injection Tutorial","href":"/others/cupti-tutorial/cupti_trace_injection/","depth":2},{"title":"CUPTI Multi-GPU Event Profiling Tutorial","href":"/others/cupti-tutorial/event_multi_gpu/","depth":2},{"title":"CUPTI Event Sampling Tutorial","href":"/others/cupti-tutorial/event_sampling/","depth":2},{"title":"CUPTI Extensions","href":"/others/cupti-tutorial/extensions/","depth":2},{"title":"CUPTI Nested Range Profiling Tutorial","href":"/others/cupti-tutorial/nested_range_profiling/","depth":2},{"title":"CUPTI NVLink Bandwidth Monitoring Tutorial","href":"/others/cupti-tutorial/nvlink_bandwidth/","depth":2},{"title":"CUPTI OpenACC Tracing Tutorial","href":"/others/cupti-tutorial/openacc_trace/","depth":2},{"title":"CUPTI Program Counter (PC) Sampling Continuous Tutorial","href":"/others/cupti-tutorial/pc_sampling_continuous/","depth":2},{"title":"CUPTI PC Sampling Start/Stop Control Tutorial","href":"/others/cupti-tutorial/pc_sampling_start_stop/","depth":2},{"title":"CUPTI PC Sampling Analysis Utility Tutorial","href":"/others/cupti-tutorial/pc_sampling_utility/","depth":2},{"title":"CUPTI PC Sampling Tutorial","href":"/others/cupti-tutorial/pc_sampling/","depth":2},{"title":"Performance Monitor Sampling Tutorial","href":"/others/cupti-tutorial/pm_sampling/","depth":2},{"title":"CUPTI Profiling API Injection Tutorial","href":"/others/cupti-tutorial/profiling_injection/","depth":2},{"title":"CUPTI Range Profiling Tutorial","href":"/others/cupti-tutorial/range_profiling/","depth":2},{"title":"NVIDIA CUPTI Tutorials","href":"/others/cupti-tutorial/","d