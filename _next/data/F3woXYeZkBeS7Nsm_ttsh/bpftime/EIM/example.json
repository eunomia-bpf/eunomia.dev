pan style=\"color:#ADBAC7\"> bits_offset</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">0</span><span style=\"color:#ADBAC7\"> nr_bits</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">8</span><span style=\"color:#ADBAC7\"> encoding</span><span style=\"color:#F47067\">=</span><span style=\"color:#ADBAC7\">(</span><span style=\"color:#F69D50\">none</span><span style=\"color:#ADBAC7\">)</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">[7] INT </span><span style=\"color:#96D0FF\">'short unsigned int'</span><span style=\"color:#ADBAC7\"> size</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">2</span><span style=\"color:#ADBAC7\"> bits_offset</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">0</span><span style=\"color:#ADBAC7\"> nr_bits</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">16</span><span style=\"color:#ADBAC7\"> encoding</span><span style=\"color:#F47067\">=</span><span style=\"color:#ADBAC7\">(</span><span style=\"color:#F69D50\">none</span><span style=\"color:#ADBAC7\">)</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">[8] INT </span><span style=\"color:#96D0FF\">'signed char'</span><span style=\"color:#ADBAC7\"> size</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">1</span><span style=\"color:#ADBAC7\"> bits_offset</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">0</span><span style=\"color:#ADBAC7\"> nr_bits</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">8</span><span style=\"color:#ADBAC7\"> encoding</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">SIGNED</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">[9] INT </span><span style=\"color:#96D0FF\">'short int'</span><span style=\"color:#ADBAC7\"> size</span><span style=\"color:#F47067\">=</span><span style=\"color:#96D0FF\">2</span>