le":"About bpftime - bpftime ideas","href":"/others/miscellaneous/bpftime-roadmap/","depth":2},{"title":"基于内核态/用户态 eBPF 实现高性能用户态文件系统功能 - 操作系统大赛赛题","href":"/others/miscellaneous/ebpf-fuse/","depth":2},{"title":"使用 eBPF 对 AI/ML 工作负载进行追踪和性能分析 - 操作系统大赛赛题","href":"/others/miscellaneous/ebpf-gpu/","depth":2},{"title":"Project Proposal for bpftime - eBPF Foundation","href":"/others/miscellaneous/ebpf-linux/","depth":2},{"title":"实现内核与用户态共同工作的 eBPF 安全框架 - 操作系统大赛赛题","href":"/others/miscellaneous/ebpf-lsm-usm/","depth":2},{"title":"Categorization of eBPF Hooks and Use Cases","href":"/others/miscellaneous/ebpf-usecases/","depth":2},{"title":"将用户态 eBPF 扩展到 MacOS、Windows、FreeBSD 等更多平台 - 操作系统大赛赛题","href":"/others/miscellaneous/ebpf-userspace-port/","depth":2},{"title":"uXDP: Frictionless XDP Deployments in Userspace (12-min talk)","href":"/others/miscellaneous/ebpf-uxdp-workshop-talk/","depth":2},{"title":"GSOC - OSPP draft proposal","href":"/others/miscellaneous/gsoc-ospp/","depth":2},{"title":"开源活动的可能想法 - eunomia-bpf 2024","href":"/others/miscellaneous/ideas/","depth":2},{"title":"bpftime talk at linux plumbers 2025","href":"/others/miscellaneous/linux-plumbers-talk/","depth":2},{"title":"Speech Script for OSDI 2025 bpftime talk \"Extending Applications Safely and Efficiently\"","href":"/others/miscellaneous/osdi-talk/","depth":2},{"title":"bpftime roadmap and ideas for 2024","href":"/others/miscellaneous/roadmap/","depth":2},{"title":"eBPF Summit 2025 bpftime talk","href":"/others/miscellaneous/talk-ebpf-summit/","depth":2},{"title":"Securing and Simplifying eBPF Deployments with WebAssembly","href":"/others/miscellaneous/wasm-bpf-kubecon/","depth":2},{"title":"talk draft in kubecon","href":"/others/miscellaneous/wasm-bpf-talk/","depth":2},{"title":"NVBit 内部机制深度分析","href":"/others/nvbit-tutorial/nvbit-internals/","depth":2},{"title":"NVBit Tutorial: Comprehensive Guide to GPU Binary Instrumentation","href":"/others/nvbit-tutorial/","depth":1},{"title":"NVBit Tutorial: Basic Block Instruction Counting","href":"/others/nvbit-tutorial/tools/instr_count_bb/","depth":3},{"title":"NVBit Tutorial: Instruction Counting with CUDA Graphs Support","href":"/others/nvbit-tutorial/tools/instr_count_cuda_graph/","depth":3},{"title":"NVBit Tutorial: Instruction Counting","href":"/others/nvbit-tutorial/tools/instr_count/","depth":3},{"title":"NVBit Tutorial: GPU-to-CPU Printing with memprintf2","href":"/others/nvbit-tutorial/tools/mem_printf2/","depth":3},{"title":"NVBit Tutorial: Memory Tracing","href":"/others/nvbit-tutorial/tools/mem_trace/","depth":3},{"title":"NVBit Tutorial: MOV Instruction Replacement","href":"/others/nvbit-tutorial/tools/mov_replace/","depth":3},{"title":"NVBit Tutorial: Opcode Histogram","href":"/others/nvbit-tutorial/tools/opcode_hist/","depth":3},{"title":"NVBit Tutorial Tools","href":"/others/nvbit-tutorial/tools/","depth":2},{"title":"NVBit Tutorial: Register Value Recording","href":"/others/nvbit-tutorial/tools/record_reg_vals/","depth":3},{"title":"hXDP: Efficient Software Packet Processing on FPGA NICs","href":"/others/papers/osdi20-brunella/","depth":2},{"title":"paper reading and translate","href":"/others/papers/","depth":1},{"title":"ebpf usecases analysis","href":"/others/usecases/","depth":1}]}]}},"__N_SSG":true}