nvbit-tutorial/tools/instr_count_bb/","depth":3},{"title":"NVBit Tutorial: Instruction Counting with CUDA Graphs Support","href":"/others/nvbit-tutorial/tools/instr_count_cuda_graph/","depth":3},{"title":"NVBit Tutorial: Instruction Counting","href":"/others/nvbit-tutorial/tools/instr_count/","depth":3},{"title":"NVBit Tutorial: GPU-to-CPU Printing with memprintf2","href":"/others/nvbit-tutorial/tools/mem_printf2/","depth":3},{"title":"NVBit Tutorial: Memory Tracing","href":"/others/nvbit-tutorial/tools/mem_trace/","depth":3},{"title":"NVBit Tutorial: MOV Instruction Replacement","href":"/others/nvbit-tutorial/tools/mov_replace/","depth":3},{"title":"NVBit Tutorial: Opcode Histogram","href":"/others/nvbit-tutorial/tools/opcode_hist/","depth":3},{"title":"NVBit Tutorial Tools","href":"/others/nvbit-tutorial/tools/","depth":2},{"title":"NVBit Tutorial: Register Value Recording","href":"/others/nvbit-tutorial/tools/record_reg_vals/","depth":3},{"title":"hXDP: Efficient Software Packet Processing on FPGA NICs","href":"/others/papers/osdi20-brunella/","depth":2},{"title":"paper reading and translate","href":"/others/papers/","depth":1},{"title":"ebpf usecases analysis","href":"/others/usecases/","depth":1}]}]}},"__N_SSG":true}