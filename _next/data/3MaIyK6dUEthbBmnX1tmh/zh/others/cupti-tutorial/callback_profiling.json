</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#F69D50\"> std</span><span style=\"color:#ADBAC7\">::endl;</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">            std</span><span style=\"color:#ADBAC7\">::cout </span><span style=\"color:#F47067\">&#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"内核时间：\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#ADBAC7\"> totalKernelTime.</span><span style=\"color:#DCBDFB\">load</span><span style=\"color:#ADBAC7\">() </span><span style=\"color:#F47067\">/</span><span style=\"color:#6CB6FF\"> 1000</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"ms\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#F69D50\"> std</span><span style=\"color:#ADBAC7\">::endl;</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">            std</span><span style=\"color:#ADBAC7\">::cout </span><span style=\"color:#F47067\">&#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"内存分配：\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#ADBAC7\"> memoryAllocated.</span><span style=\"color:#DCBDFB\">load</span><span style=\"color:#ADBAC7\">() </span><span style=\"color:#F47067\">/</span><span style=\"color:#ADBAC7\"> (</span><span style=\"color:#6CB6FF\">1024</span><span style=\"color:#F47067\">*</span><span style=\"color:#6CB6FF\">1024</span><span style=\"color:#ADBAC7\">) </span><span style=\"color:#F47067\">&#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"MB\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#F69D50\"> std</span><span style=\"color:#ADBAC7\">::endl;</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">            </span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">            std</span><span style=\"color:#ADBAC7\">::</span><span style=\"color:#F69D50\">this_thread</span><span style=\"color:#ADBAC7\">::</span><span style=\"color:#DCBDFB\">sleep_for</span><span style=\"color:#ADBAC7\">(</span><span style=\"color:#F69D50\">std</span><span style=\"color:#ADBAC7\">::</span><span style=\"color:#DCBDFB\">seconds</span><span style=\"color:#ADBAC7\">(</span><span style=\"color:#6CB6FF\">1</span><span style=\"color:#ADBAC7\">));</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">        }</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    }</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">};</span></span></code></pre></figure>\n<h2 id=\"与开发工作流程集成\">与开发工作流程集成</h2>\n<h3 id=\"自动化性能测试\">自动化性能测试</h3>\n<figure data-rehype-pretty-code-figure=\"\"><pre tabindex=\"0\" data-language=\"bash\" data-theme=\"github-dark-dimmed\"><code data-language=\"bash\" data-theme=\"github-dark-dimmed\" style=\"display: grid;\"><span data-line=\"\"><span style=\"color:#768390\"># 性能回归测试</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">./callback_profiling</span><span style=\"color:#6CB6FF\"> --baseline</span><span style=\"color:#F47067\"> ></span><span style=\"color:#96D0FF\"> baseline_profile.txt</span></span>\n<span data-line=\"\"><span style=\"color:#768390\"># ... 进行代码更改 ...</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">./callback_profiling</span><span style=\"color:#6CB6FF\"> --compare</span><span style=\"color:#96D0FF\"> baseline_profile.txt</span><span style=\"color:#F47067\"> ></span><span style=\"color:#96D0FF\"> regression_report.txt</span></span></code></pre></figure>\n<h3 id=\"持续集成\">持续集成</h3>\n<figure data-rehype-pretty-code-figure=\"\"><pre tabindex=\"0\" data-language=\"cpp\" data-theme=\"github-dark-dimmed\"><code data-language=\"cpp\" data-theme=\"github-dark-dimmed\" style=\"display: grid;\"><span data-line=\"\"><span style=\"color:#768390\">// CI友好的输出格式</span></span>\n<span data-line=\"\"><span style=\"color:#F47067\">void</span><span style=\"color:#DCBDFB\"> generateCIReport</span><span style=\"color:#ADBAC7\">(</span><span style=\"color:#F47067\">const</span><span style=\"color:#F69D50\"> ProfileData</span><span style=\"color:#F47067\">&#x26;</span><span style=\"color:#F69D50\"> data</span><span style=\"color:#ADBAC7\">) {</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    json report;</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    report[</span><span style=\"color:#96D0FF\">\"total_api_time\"</span><span style=\"color:#ADBAC7\">] </span><span style=\"color:#F47067\">=</span><span style=\"color:#ADBAC7\"> data.totalAPITime;</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    report[</span><span style=\"color:#96D0FF\">\"memory_efficiency\"</span><span style=\"color:#ADBAC7\">] </span><span style=\"color:#F47067\">=</span><span style=\"color:#ADBAC7\"> data.memoryEfficiency;</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    report[</span><span style=\"color:#96D0FF\">\"kernel_utilization\"</span><span style=\"color:#ADBAC7\">] </span><span style=\"color:#F47067\">=</span><span style=\"color:#ADBAC7\"> data.kernelUtilization;</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    </span></span>\n<span data-line=\"\"><span style=\"color:#768390\">    // 如果性能显著下降，则失败CI</span></span>\n<span data-line=\"\"><span style=\"color:#F47067\">    if</span><span style=\"color:#ADBAC7\"> (data.totalAPITime </span><span style=\"color:#F47067\">></span><span style=\"color:#ADBAC7\"> PERFORMANCE_THRESHOLD) {</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">        std</span><span style=\"color:#ADBAC7\">::</span><span style=\"color:#DCBDFB\">exit</span><span style=\"color:#ADBAC7\">(</span><span style=\"color:#6CB6FF\">1</span><span style=\"color:#ADBAC7\">);</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    }</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">}</span></span></code></pre></figure>\n<h2 id=\"故障排除\">故障排除</h2>\n<h3 id=\"常见问题\">常见问题</h3>\n<ol>\n<li><strong>回调未触发</strong>：验证回调注册和域选择</li>\n<li><strong>高开销</strong>：减少回调频率或优化数据收集</li>\n<li><strong>线程安全</strong>：确保多线程应用程序中的适当同步</li>\n<li><strong>内存泄漏</strong>：检查回调数据结构的适当清理</li>\n</ol>\n<h3 id=\"调试技巧\">调试技巧</h3>\n<ol>\n<li><strong>从简单回调开始</strong>：在添加复杂分析之前从基本时序开始</li>\n<li><strong>使用选择性性能分析</strong>：专注于特定API以减少开销</li>\n<li><strong>使用已知应用程序验证</strong>：首先使用CUDA示例进行测试</li>\n<li><strong>监控开销</strong>：测量性能分析对应用程序性能的影响</li>\n</ol>\n<h2 id=\"下一步\">下一步</h2>\n<ul>\n<li>扩展示例以分析应用程序的特定方面</li>\n<li>将回调性能分析集成到您的开发和测试过程中</li>\n<li>与其他CUPTI功能结合进行全面分析</li>\n<li>为您的用例开发自定义指标和分析算法</li>\n<li>为回调性能分析数据创建可视化工具</li>\n</ul>","headings":[{"id":"简介","text":"简介","depth":2},{"id":"您将学到什么","text":"您将学到什么","depth":2},{"id":"理解基于回调的性能分析","text":"理解基于回调的性能分析","depth":2},{"id":"关键概念","text":"关键概念","depth":2},{"id":"回调类型","text":"回调类型","depth":3},{"id":"回调阶段","text":"回调阶段","depth":3},{"id":"回调数据","text":"回调数据","depth":3},{"id":"构建示例","text":"构建示例","depth":2},{"id":"先决条件","text":"先决条件","depth":3},{"id":"构建过程","text":"构建过程","depth":3},{"id":"代码架构","text":"代码架构","depth":2},{"id":"主要组件","text":"主要组件","depth":3},{"id":"核心实现","text":"核心实现","depth":3},{"id":"运行示例","text":"运行示例","depth":2},{"id":"基本执行","text":"基本执行","depth":3},{"id":"示例输出","text":"示例输出","depth":3},{"id":"详细分析功能","text":"详细分析功能","depth":2},{"id":"api调用跟踪","text":"API调用跟踪","depth":3},{"id":"内存使用分析","text":"内存使用分析","depth":3},{"id":"内核启动分析","text":"内核启动分析","depth":3},{"id":"高级功能","text":"高级功能","depth":2},{"id":"选择性性能分析","text":"选择性性能分析","depth":3},{"id":"性能指标集成","text":"性能指标集成","depth":3},{"id":"多线程分析","text":"多线程分析","depth":3},{"id":"实际应用","text":"实际应用","depth":2},{"id":"性能瓶颈检测","text":"性能瓶颈检测","depth":3},{"id":"应用程序特征化","text":"应用程序特征化","depth":3},{"id":"实时监控","text":"实时监控","depth":3},{"id":"与开发工作流程集成","text":"与开发工作流程集成","depth":2},{"id":"自动化性能测试","text":"自动化性能测试","depth":3},{"id":"持续集成","text":"持续集成","depth":3},{"id":"故障排除","text":"故障排除","depth":2},{"id":"常见问题","text":"常见问题","depth":3},{"id":"调