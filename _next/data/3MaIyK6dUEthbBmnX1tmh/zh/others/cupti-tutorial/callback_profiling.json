an data-line=\"\"><span style=\"color:#F47067\">    int</span><span style=\"color:#ADBAC7\"> averageOccupancy;</span></span>\n<span data-line=\"\"><span style=\"color:#ADBAC7\">    </span></span>\n<span data-line=\"\"><span style=\"color:#F47067\">    void</span><span style=\"color:#DCBDFB\"> generateReport</span><span style=\"color:#ADBAC7\">() {</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">        std</span><span style=\"color:#ADBAC7\">::cout </span><span style=\"color:#F47067\">&#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"计算/内存比率：\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#ADBAC7\"> computeToMemoryRatio </span><span style=\"color:#F47067\">&#x3C;&#x3C;</span><span style=\"color:#F69D50\"> std</span><span style=\"color:#ADBAC7\">::endl;</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">        std</span><span style=\"color:#ADBAC7\">::cout </span><span style=\"color:#F47067\">&#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"异步利用率：\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#ADBAC7\"> asyncUtilization </span><span style=\"color:#F47067\">*</span><span style=\"color:#6CB6FF\"> 100</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"%\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#F69D50\"> std</span><span style=\"color:#ADBAC7\">::endl;</span></span>\n<span data-line=\"\"><span style=\"color:#F69D50\">        std</span><span style=\"color:#ADBAC7\">::cout </span><span style=\"color:#F47067\">&#x3C;&#x3C;</span><span style=\"color:#96D0FF\"> \"峰值内存使用：\"</span><span style=\"color:#F47067\"> &#x3C;&#x3C;</span><span style=\"color:#ADBAC7\"> peakMemoryUsage </span><span style=\"color:#F47067\">/</span><span style=\"color:#ADBAC7\"> (</span><span style=\"color:#6CB6FF\">1024</span><span style=\"color:#F47067\">*</span><span style=\"color:#6CB6FF\">1024</span><span style=\"color:#ADBAC7\