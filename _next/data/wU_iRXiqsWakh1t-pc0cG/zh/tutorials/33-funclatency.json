2},{"title":"eBPF 示例：使用 CUPTI 构建 GPU 火焰图分析器","href":"/zh/tutorials/xpu/flamegraph/","depth":2},{"title":"eBPF 实例教程：使用内核跟踪点监控 GPU 驱动活动","href":"/zh/tutorials/xpu/gpu-kernel-driver/","depth":2},{"title":"eBPF 实例教程：跟踪 Intel NPU 内核驱动操作","href":"/zh/tutorials/xpu/npu-kernel-driver/","depth":2}]}]}},"__N_SSG":true}