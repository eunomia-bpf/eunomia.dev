{
  "name": "eunomia-custom-web",
  "private": true,
  "scripts": {
    "clean:generated": "node scripts/clean-generated-output.mjs",
    "generate:site-config": "tsx scripts/generate-site-config.ts",
    "generate:content-index": "npm run generate:site-config && tsx scripts/generate-content-index.ts",
    "generate:search-index": "tsx scripts/generate-search-index.ts",
    "generate:static-assets": "tsx scripts/generate-static-assets.ts",
    "generate:static-metadata": "tsx scripts/generate-static-metadata.ts",
    "generate:content-artifacts": "npm run clean:generated && npm run generate:content-index && npm run generate:search-index && npm run generate:static-assets && npm run generate:static-metadata",
    "dev": "npm run generate:content-artifacts && next dev",
    "build": "npm run generate:content-artifacts && NEXT_DIST_DIR=${NEXT_DIST_DIR:-.static-builds/export} next build && NEXT_DIST_DIR=${NEXT_DIST_DIR:-.static-builds/export} node scripts/finalize-static-export.mjs && node scripts/generate-legacy-redirects.mjs",
    "start": "node scripts/assert-content-artifacts.mjs && node ../test/scripts/lib/static-server.mjs",
    "lint:app": "eslint components lib pages scripts tests *.config.* --config ./eslint.config.mjs --max-warnings=0",
    "lint:test": "cd ../test && ../app/node_modules/.bin/eslint scripts *.mjs --config ./eslint.config.mjs --max-warnings=0",
    "lint": "npm run lint:app && npm run lint:test",
    "typecheck": "npm run generate:content-index && tsc --noEmit",
    "test:content": "npm run generate:content-artifacts && node --import tsx --test --test-concurrency=1 tests/content.test.ts",
    "verify": "npm run lint && node scripts/verify.mjs"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "mermaid": "^11.12.0",
    "next": "16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@next/eslint-plugin-next": "16.2.6",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
